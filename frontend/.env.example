# Dev server
VITE_DEV_PORT=5173

# API – use /api in dev (Vite proxies to backend). In production set full URL e.g. https://api.example.com/api
VITE_API_BASE_URL=/api

# Backend URL for Vite dev proxy only (not exposed to browser)
VITE_API_PROXY_TARGET=http://localhost:3000

# App
VITE_APP_TITLE=Fleet Management BI
VITE_DEFAULT_LANGUAGE=en

# Auth – localStorage key for JWT
VITE_AUTH_TOKEN_KEY=fleet-bi-token
